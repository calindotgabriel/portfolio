---
import BaseLayout from "../layouts/BaseLayout.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import ContactFooter from "../components/ContactFooter.astro";
import TechIcon from "../components/TechIcon.astro";
import { projects } from "../data/projects";

---

<BaseLayout 
  title="Calin Gabriel - Senior Node.js / TypeScript Engineer"
  description="Senior Node.js/TypeScript engineer for backend-heavy product systems, remote EU B2B contracts, migrations, APIs, testing, and performance."
>
  <!-- HEADER NAVIGATION -->
  <header class="header-nav">
    <div class="nav-container">
      <div class="nav-logo">
        <a href="#hero">
          <span class="logo-text">Calin Gabriel</span>
          <span class="logo-subtitle">Senior Node.js / TypeScript Engineer</span>
        </a>
      </div>
      
      <!-- Desktop Navigation -->
      <nav class="nav-desktop">
        <a href="#hero" class="nav-link">Home</a>
        <a href="#about" class="nav-link">About</a>
        <a href="#projects" class="nav-link">Projects</a>
        <a href="#contact" class="nav-link">Contact</a>
      </nav>

      <div class="nav-actions">
        <ThemeToggle />
      </div>
      
      <!-- Mobile Hamburger -->
      <button class="hamburger" id="hamburger" aria-label="Toggle navigation">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
    
    <!-- Mobile Navigation -->
    <nav class="nav-mobile" id="nav-mobile">
      <a href="#hero" class="nav-mobile-link">Home</a>
      <a href="#about" class="nav-mobile-link">About</a>
      <a href="#projects" class="nav-mobile-link">Projects</a>
      <a href="#contact" class="nav-mobile-link">Contact</a>
    </nav>
  </header>

  <!-- HERO SECTION -->
    <section id="hero" class="hero-section">
      <div class="hero-content">
        <span class="hero-badge">Remote EU B2B contracts / available immediately</span>

        <h1 class="hero-title">Senior Node.js / TypeScript engineer for backend-heavy product systems</h1>

        <p class="hero-tagline">
          I help teams reduce delivery risk in migrations, data-heavy APIs,
          integrations, and tested React/Node systems for companies like
          <strong>Scout24</strong>, <strong>RWE</strong>, and <strong>NETS</strong>.
        </p>

        <p class="hero-sub">
          Best fit: long-term remote EU B2B contracts where production quality,
          measured performance, and clear senior communication matter more than
          another generic full-stack profile.
        </p>

        <div class="proof-strip" aria-label="Contract proof points">
          <div class="proof-item">
            <span class="proof-value">45min -> 12min</span>
            <span class="proof-label">RWE export pipeline</span>
          </div>
          <div class="proof-item">
            <span class="proof-value">65% faster</span>
            <span class="proof-label">API responses</span>
          </div>
          <div class="proof-item">
            <span class="proof-value">Scout24</span>
            <span class="proof-label">tested distributed platform</span>
          </div>
          <div class="proof-item">
            <span class="proof-value">Payments / energy / search</span>
            <span class="proof-label">production domains</span>
          </div>
        </div>

        <div class="hero-cta">
          <a href="mailto:contact@calingabriel.com?subject=Senior%20Node.js%20%2F%20TypeScript%20contract" class="cta-primary">Book a 20-minute fit call</a>
          <a href="#hire-me-for" class="cta-secondary">What I can take on</a>
          <a href="/resume" class="cta-secondary">View CV</a>
        </div>
      </div>
    </section>

    <!-- CONTRACT OFFERS -->
    <section id="hire-me-for" class="offers-section">
      <div class="offers-container">
        <div class="offers-header">
          <span class="section-kicker">Hire me for</span>
          <h2>Senior delivery where the risk is in the backend, data, and production edges.</h2>
          <p>
            I am not positioning as a cheap task executor. The strongest fit is a team that
            needs a senior engineer who can enter an existing system, understand the domain,
            and move important work without adding chaos.
          </p>
        </div>

        <div class="offers-grid">
          <article class="offer-card">
            <span class="offer-number">01</span>
            <h3>Legacy-to-Node / NestJS migration</h3>
            <p>
              Replace risky legacy paths with maintainable TypeScript services, using tests
              and narrow migration slices so the team keeps shipping while the system changes.
            </p>
            <strong>Proof: RWE Java-to-NestJS migration work.</strong>
          </article>
          <article class="offer-card">
            <span class="offer-number">02</span>
            <h3>API, data, and backend reliability</h3>
            <p>
              Profile slow flows, separate bottlenecks from guesses, improve data access,
              and keep production workflows responsive under real usage.
            </p>
            <strong>Proof: 65% faster APIs and exports cut from 45 minutes to 12.</strong>
          </article>
          <article class="offer-card">
            <span class="offer-number">03</span>
            <h3>Tested React / Node product delivery</h3>
            <p>
              Ship product changes in mature systems where SEO, integrations, reviews,
              and coverage all matter to release confidence.
            </p>
            <strong>Proof: ImmoScout24 search, listing, SEO, and Iterable work.</strong>
          </article>
        </div>
      </div>
    </section>

    <!-- ABOUT SECTION -->
    <section id="about" class="about-section">
      <div class="about-container">
        <h2 class="about-heading">Why this profile fits contract delivery</h2>

        <div class="about-timeline">
          <!-- Past -->
          <div class="about-phase">
            <div class="phase-marker">
              <div class="phase-dot"></div>
              <div class="phase-line"></div>
            </div>
            <div class="phase-content">
              <span class="phase-label">Delivery baseline</span>
              <h3 class="phase-title">Started early, learned by shipping production work</h3>
              <p class="phase-text">
                At 16 I won an internship contest in Galati and turned it into my first
                software job. I learned Linux and web development on real work before moving
                to Cluj-Napoca for Computer Science at Babes-Bolyai University, where I put
                formal structure around the practical habits I had already started building.
              </p>
            </div>
          </div>

          <!-- Present -->
          <div class="about-phase">
            <div class="phase-marker">
              <div class="phase-dot phase-dot-active"></div>
              <div class="phase-line"></div>
            </div>
            <div class="phase-content">
              <span class="phase-label">Current fit</span>
              <h3 class="phase-title">Senior Node.js / TypeScript delivery across product domains</h3>
              <p class="phase-text">
                I have worked across payments, energy, real estate, e-commerce, and publishing,
                including DAX-listed companies and major European platforms. My strongest work
                is in backend-heavy full-stack systems: Node.js, React, databases, testing,
                integration work, and performance improvements that are measured rather than guessed.
              </p>
            </div>
          </div>

          <!-- Future -->
          <div class="about-phase">
            <div class="phase-marker">
              <div class="phase-dot phase-dot-future"></div>
            </div>
            <div class="phase-content">
              <span class="phase-label">Contract preference</span>
              <h3 class="phase-title">Looking for high-context teams with real system risk</h3>
              <p class="phase-text">
                I am looking for long-term remote EU B2B contracts where engineers own outcomes,
                communicate clearly, and care about maintainability. The best fit is a product
                or platform team with enough domain complexity to reward careful senior work.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PROJECTS COMPACT -->
    <section id="projects" class="projects-section">
      <div class="projects-container">
        <div class="projects-header">
          <h2>Case Studies</h2>
          <p>Real problems, real decisions, real outcomes.</p>
        </div>

        <div class="projects-grid">
          {projects.map((project, index) => (
            <a href={`/projects/${project.id}`} class="project-link">
              <div
                class:list={[
                  "project-card",
                  index < 2 ? "project-card-large" : "project-card-compact",
                  index === 1 ? "project-card-reverse" : "",
                ]}
              >
                {index === 1 && (
                  <div class="project-results">
                    <div class="results-header">
                      <span class="results-title">Impact</span>
                    </div>
                    <ul class="results-list">
                      {project.results.map((result) => <li>{result}</li>)}
                    </ul>
                  </div>
                )}

                <div class={index === 2 ? "project-compact-content" : ""}>
                  <div class={index === 2 ? "project-compact-info" : ""}>
                    <div class="project-header">
                      <h3 class={index === 2 ? "project-compact-title" : "project-title"}>
                        {project.homeTitle}
                      </h3>
                      <span
                        class:list={[
                          "project-badge",
                          {
                            "badge-live": project.status === "LIVE",
                            "badge-enterprise": project.status === "ENTERPRISE",
                            "badge-agency": project.status === "AGENCY",
                          },
                        ]}
                      >
                        {project.status}
                      </span>
                    </div>
                    <p class={index === 2 ? "project-compact-description" : "project-description"}>
                      {project.caseStudySummary}
                    </p>
                  </div>
                  <div class={index === 2 ? "project-compact-tech" : "project-tech-container"}>
                    {project.tech.map((tech) => (
                      <span class="tech-pill"><TechIcon technology={tech} size={16} />{tech}</span>
                    ))}
                  </div>
                </div>

                {index !== 1 && index < 2 && (
                  <div class="project-results">
                    <div class="results-header">
                      <span class="results-title">Impact</span>
                    </div>
                    <ul class="results-list">
                      {project.results.map((result) => <li>{result}</li>)}
                    </ul>
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <ContactFooter />

    <style>
      /* HEADER NAVIGATION */
      .header-nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        background: var(--nav-bg);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border);
        z-index: 1000;
        transition: all 0.3s ease;
      }

      .nav-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 70px;
      }

      .nav-logo a {
        text-decoration: none;
        color: var(--text);
        display: flex;
        flex-direction: column;
        line-height: 1.1;
      }

      .logo-text {
        font-size: 1.3rem;
        font-weight: 700;
        background: linear-gradient(135deg, #0f172a 0%, #9a3412 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .logo-subtitle {
        font-size: 0.75rem;
        color: var(--text-muted);
        font-weight: 500;
      }

      .nav-desktop {
        display: flex;
        gap: 2rem;
        align-items: center;
      }

      .nav-link {
        text-decoration: none;
        color: var(--text);
        font-weight: 500;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        position: relative;
        padding: 0.5rem 0;
      }

      .nav-actions {
        display: flex;
        align-items: center;
        margin-left: 0.5rem;
      }

      .nav-link::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0;
        height: 2px;
        background: var(--secondary);
        transition: width 0.3s ease;
      }

      .nav-link:hover {
        color: var(--primary);
      }

      .nav-link:hover::after {
        width: 100%;
      }

      /* Hamburger Menu */
      .hamburger {
        display: none;
        flex-direction: column;
        gap: 4px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        transition: all 0.3s ease;
      }

      .hamburger-line {
        width: 25px;
        height: 2px;
        background: var(--text);
        transition: all 0.3s ease;
        transform-origin: center;
      }

      .hamburger.active .hamburger-line:nth-child(1) {
        transform: rotate(45deg) translate(6px, 6px);
      }

      .hamburger.active .hamburger-line:nth-child(2) {
        opacity: 0;
      }

      .hamburger.active .hamburger-line:nth-child(3) {
        transform: rotate(-45deg) translate(6px, -6px);
      }

      /* Mobile Navigation */
      .nav-mobile {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: var(--nav-bg-solid);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border);
        padding: 2rem;
        display: none;
        flex-direction: column;
        gap: 1.5rem;
        animation: slideDown 0.3s ease;
      }

      .nav-mobile.active {
        display: flex;
      }

      .nav-mobile-link {
        text-decoration: none;
        color: var(--text);
        font-weight: 500;
        font-size: 1.1rem;
        padding: 1rem 0;
        border-bottom: 1px solid var(--border);
        transition: all 0.3s ease;
      }

      .nav-mobile-link:hover {
        color: var(--primary);
        transform: translateX(10px);
      }

      .nav-mobile-link:last-child {
        border-bottom: none;
      }

      @keyframes slideDown {
        from {
          opacity: 0;
          transform: translateY(-20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* Responsive Design */
      @media (max-width: 768px) {
        .nav-desktop {
          display: none;
        }

        .hamburger {
          display: flex;
        }

        .nav-container {
          padding: 0 1rem;
        }
      }

      /* Add padding to body to account for fixed header */
      body {
        padding-top: 70px;
      }


      /* HERO SECTION */
      .hero-section {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--hero-bg);
        position: relative;
      }

      .hero-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background:
          radial-gradient(ellipse at 20% 50%, rgba(15, 23, 42, 0.4) 0%, transparent 50%),
          radial-gradient(ellipse at 80% 50%, rgba(154, 52, 18, 0.1) 0%, transparent 50%);
        pointer-events: none;
      }

      .hero-content {
        position: relative;
        z-index: 10;
        max-width: 980px;
        margin: 0 auto;
        padding: 2rem;
        color: white;
      }

      .hero-badge {
        display: inline-block;
        font-size: 0.85rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.7);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 50px;
        padding: 0.5rem 1.25rem;
        margin-bottom: 2rem;
        animation: fadeInUp 0.8s ease both;
      }

      .hero-title {
        font-size: 3.65rem;
        font-weight: 800;
        margin-bottom: 1.5rem;
        line-height: 1.1;
        color: white;
        animation: fadeInUp 0.8s ease 0.15s both;
      }

      .hero-tagline {
        font-size: 1.3rem;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.85);
        margin-bottom: 1.25rem;
        animation: fadeInUp 0.8s ease 0.3s both;
      }

      .hero-tagline strong {
        color: white;
        font-weight: 600;
      }

      .hero-sub {
        font-size: 1.05rem;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.5);
        margin-bottom: 1.5rem;
        animation: fadeInUp 0.8s ease 0.45s both;
      }

      .proof-strip {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.75rem;
        margin: 2rem 0 2.25rem;
        animation: fadeInUp 0.8s ease 0.52s both;
      }

      .proof-item {
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: rgba(255, 255, 255, 0.06);
        border-radius: 8px;
        padding: 1rem;
        min-height: 104px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      .proof-value {
        color: white;
        font-weight: 800;
        font-size: 1.02rem;
        line-height: 1.25;
      }

      .proof-label {
        color: rgba(255, 255, 255, 0.58);
        font-size: 0.82rem;
        line-height: 1.35;
      }

      .hero-cta {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        animation: fadeInUp 0.8s ease 0.6s both;
      }

      .offers-section {
        padding: 96px 0;
        background: var(--surface);
      }

      .offers-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 2rem;
      }

      .offers-header {
        max-width: 780px;
        margin-bottom: 2.25rem;
      }

      .section-kicker {
        display: inline-block;
        color: var(--primary);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 0.85rem;
      }

      .offers-header h2 {
        color: var(--text);
        font-size: 2.4rem;
        line-height: 1.15;
        margin-bottom: 1rem;
      }

      .offers-header p {
        color: var(--text-muted);
        font-size: 1.05rem;
        line-height: 1.75;
      }

      .offers-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
      }

      .offer-card {
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1.5rem;
        background: var(--card-bg);
      }

      .offer-number {
        display: inline-block;
        color: var(--text-subtle);
        font-weight: 800;
        font-size: 0.85rem;
        margin-bottom: 1rem;
      }

      .offer-card h3 {
        color: var(--text);
        font-size: 1.2rem;
        line-height: 1.25;
        margin-bottom: 0.9rem;
      }

      .offer-card p {
        color: var(--text-muted);
        font-size: 0.96rem;
        line-height: 1.65;
        margin-bottom: 1rem;
      }

      .offer-card strong {
        display: block;
        color: var(--text);
        font-size: 0.9rem;
        line-height: 1.45;
      }

      .cta-primary {
        display: inline-block;
        background: white;
        color: var(--dark);
        text-decoration: none;
        padding: 0.85rem 1.75rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s ease;
      }

      .cta-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(255, 255, 255, 0.15);
      }

      .cta-secondary {
        display: inline-block;
        color: rgba(255, 255, 255, 0.7);
        text-decoration: none;
        padding: 0.85rem 1.75rem;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        font-weight: 500;
        font-size: 0.95rem;
        transition: all 0.3s ease;
      }

      .cta-secondary:hover {
        color: white;
        border-color: rgba(255, 255, 255, 0.4);
      }

      .project-link {
        text-decoration: none;
        color: inherit;
      }

      .projects-section {
        padding: 100px 0;
        background: var(--surface-soft);
      }

      .projects-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 2rem;
      }

      .projects-header {
        margin-bottom: 2.5rem;
      }

      .projects-header h2 {
        font-size: 2.5rem;
        color: var(--text);
        margin-bottom: 0.75rem;
      }

      .projects-header p {
        color: var(--text-muted);
      }

      .projects-grid {
        display: grid;
        gap: 1.5rem;
      }

      .project-card-large {
        display: grid;
        grid-template-columns: minmax(0, 1.5fr) minmax(240px, 0.8fr);
        gap: 2rem;
        align-items: start;
      }

      .project-card-reverse {
        grid-template-columns: minmax(240px, 0.8fr) minmax(0, 1.5fr);
      }

      .project-card-compact {
        padding: 2rem;
      }

      .project-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
      }

      .project-title,
      .project-compact-title {
        color: var(--text);
        margin: 0;
      }

      .project-description,
      .project-compact-description {
        font-size: 1rem;
        line-height: 1.7;
        color: var(--text-muted);
        margin-bottom: 1.25rem;
      }

      .project-tech-container,
      .project-compact-tech {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
      }

      .project-compact-content {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1.5rem;
        align-items: center;
      }

      .project-results {
        background: var(--card-soft-bg);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1.25rem;
      }

      .results-title {
        display: inline-block;
        color: var(--text);
        font-weight: 700;
        margin-bottom: 0.75rem;
      }

      .results-list {
        list-style: none;
        display: grid;
        gap: 0.55rem;
      }

      .results-list li {
        color: var(--text-muted);
        font-size: 0.95rem;
      }

      .project-badge {
        padding: 0.25rem 0.65rem;
        border-radius: 999px;
        color: white;
        font-size: 0.72rem;
        font-weight: 700;
      }

      .badge-live { background: #0f766e; }
      .badge-enterprise { background: var(--primary-dark); }
      .badge-agency { background: #475569; }

      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (max-width: 768px) {
        .hero-title {
          font-size: 2.25rem;
        }

        .hero-tagline {
          font-size: 1.1rem;
        }

        .proof-strip,
        .offers-grid {
          grid-template-columns: 1fr;
        }

        .proof-item {
          min-height: auto;
          gap: 0.5rem;
        }

        .offers-section {
          padding: 72px 0;
        }

        .offers-header h2 {
          font-size: 2rem;
        }

        .hero-cta {
          flex-direction: column;
        }

        .cta-primary,
        .cta-secondary {
          text-align: center;
        }

        .projects-section {
          padding: 72px 0;
        }

        .project-card-large,
        .project-card-reverse,
        .project-compact-content {
          grid-template-columns: 1fr;
        }
      }      /* ABOUT SECTION */
      .about-section {
        padding: 100px 0;
        background: linear-gradient(180deg, var(--surface) 0%, var(--surface-soft) 100%);
      }

      .about-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 2rem;
      }

      .about-heading {
        font-size: 2.5rem;
        font-weight: 800;
        text-align: center;
        margin-bottom: 4rem;
        color: var(--text);
      }

      .about-timeline {
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      .about-phase {
        display: flex;
        gap: 2rem;
        padding-bottom: 3rem;
      }

      .about-phase:last-child {
        padding-bottom: 0;
      }

      .phase-marker {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex-shrink: 0;
        width: 20px;
      }

      .phase-dot {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: var(--text-subtle);
        border: 3px solid var(--border-strong);
        flex-shrink: 0;
        position: relative;
        z-index: 2;
      }

      .phase-dot-active {
        background: var(--secondary);
        border-color: rgba(154, 52, 18, 0.3);
        box-shadow: 0 0 12px rgba(154, 52, 18, 0.4);
      }

      .phase-dot-future {
        background: var(--primary);
        border-color: var(--border-strong);
      }

      .phase-line {
        width: 2px;
        flex-grow: 1;
        background: linear-gradient(180deg, var(--border-strong) 0%, var(--border) 100%);
        margin-top: 0.5rem;
      }

      .phase-content {
        padding-top: 0;
      }

      .phase-label {
        display: inline-block;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--primary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.5rem;
      }

      .phase-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 0.75rem;
        line-height: 1.3;
      }

      .phase-text {
        font-size: 1.05rem;
        line-height: 1.75;
        color: var(--text-muted);
      }

      .phase-text strong {
        color: var(--text);
        font-weight: 600;
      }

      @media (max-width: 768px) {
        .about-heading {
          font-size: 2rem;
        }

        .about-phase {
          gap: 1.25rem;
        }

        .phase-title {
          font-size: 1.2rem;
        }

        .phase-text {
          font-size: 1rem;
        }
      }

    </style>

    <script>
      // Hamburger menu functionality
      document.addEventListener('DOMContentLoaded', function() {
        const hamburger = document.getElementById('hamburger');
        const navMobile = document.getElementById('nav-mobile');
        const mobileLinks = document.querySelectorAll('.nav-mobile-link');
        const allNavLinks = document.querySelectorAll('.nav-link, .nav-mobile-link');
        const header = document.querySelector('.header-nav') as HTMLElement;

        if (!hamburger || !navMobile || !header) return;

        // Toggle mobile menu
        hamburger.addEventListener('click', function() {
          hamburger.classList.toggle('active');
          navMobile.classList.toggle('active');
        });

        // Close mobile menu when clicking on a link
        mobileLinks.forEach(link => {
          link.addEventListener('click', function() {
            hamburger.classList.remove('active');
            navMobile.classList.remove('active');
          });
        });

        // Smooth scroll to sections
        allNavLinks.forEach(link => {
          link.addEventListener('click', function(e) {
            e.preventDefault();
            const href = (e.target as HTMLAnchorElement).getAttribute('href');
            if (!href) return;
            
            const targetSection = document.querySelector(href);
            
            if (targetSection) {
              const headerHeight = 70;
              const offsetTop = (targetSection as HTMLElement).offsetTop - headerHeight;
              
              window.scrollTo({
                top: offsetTop,
                behavior: 'smooth'
              });
            }
          });
        });

        // Header background on scroll
        let lastScrollY = window.scrollY;

        window.addEventListener('scroll', function() {
          const currentScrollY = window.scrollY;
          
          if (currentScrollY > 50) {
            header.style.background = 'var(--nav-bg-solid)';
            header.style.boxShadow = 'var(--nav-shadow)';
          } else {
            header.style.background = 'var(--nav-bg)';
            header.style.boxShadow = 'none';
          }
          
          lastScrollY = currentScrollY;
        });

        // Close mobile menu when clicking outside
        document.addEventListener('click', function(e) {
          const target = e.target as Node;
          if (!header.contains(target) && navMobile.classList.contains('active')) {
            hamburger.classList.remove('active');
            navMobile.classList.remove('active');
          }
        });
      });
    </script>
</BaseLayout>
