---
import BaseLayout from "../layouts/BaseLayout.astro";
import TechIcon from "../components/TechIcon.astro";
---

<BaseLayout 
  title="Calin Gabriel - Senior Full Stack Developer"
  description="Senior Full Stack Developer building scalable distributed systems with Node.js, React, and cloud infrastructure. 6+ years delivering for enterprise clients across Europe."
>
  <header class="header-nav">
    <div class="nav-container">
      <div class="nav-logo">
        <a href="#hero">
          <span class="logo-text">Calin Gabriel</span>
          <span class="logo-subtitle">Senior Software Engineer</span>
        </a>
      </div>
      
      <nav class="nav-desktop">
        <a href="#hero" class="nav-link">Home</a>
        <a href="#about" class="nav-link">About</a>
        <a href="#projects" class="nav-link">Projects</a>
        <a href="#contact" class="nav-link">Contact</a>
      </nav>
      
      <button class="hamburger" id="hamburger" aria-label="Toggle navigation">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
    
    <nav class="nav-mobile" id="nav-mobile">
      <a href="#hero" class="nav-mobile-link">Home</a>
      <a href="#about" class="nav-mobile-link">About</a>
      <a href="#projects" class="nav-mobile-link">Projects</a>
      <a href="#contact" class="nav-mobile-link">Contact</a>
    </nav>
  </header>

  <section id="hero" class="hero-section">
      <div class="hero-content">
        <span class="hero-badge">Open to Opportunities</span>

        <h1 class="hero-title">Calin Gabriel</h1>

        <p class="hero-tagline">
          I architect and build robust distributed systems for enterprise clients like
          <strong>Scout24</strong>, <strong>RWE</strong>, and <strong>NETS</strong>.
        </p>

        <p class="hero-sub">
          6+ years of shipping scalable, test-driven backend solutions across Europe, specializing in performant APIs, complex domains, and cloud infrastructure.
        </p>

        <div class="hero-cta">
          <a href="#about" class="cta-primary">Professional Journey</a>
          <a href="#projects" class="cta-secondary">See Case Studies</a>
          <a href="/resume" class="cta-secondary">View CV</a>
        </div>
      </div>
    </section>

    <section id="about" class="about-section">
      <div class="about-container">
        <h2 class="about-heading">Engineering Background</h2>

        <div class="about-timeline">
          <div class="about-phase">
            <div class="phase-marker">
              <div class="phase-dot"></div>
              <div class="phase-line"></div>
            </div>
            <div class="phase-content">
              <span class="phase-label">The Foundation</span>
              <h3 class="phase-title">Bridging Theory and Practice</h3>
              <p class="phase-text">
                I started out in web development early, gaining hands-on experience with Linux servers and core web infrastructure. I later formalized this practical instinct with a Computer Science degree from Babes-Bolyai University in Cluj-Napoca, ensuring my architectural decisions are backed by strong theoretical fundamentals.
              </p>
            </div>
          </div>

          <div class="about-phase">
            <div class="phase-marker">
              <div class="phase-dot phase-dot-active"></div>
              <div class="phase-line"></div>
            </div>
            <div class="phase-content">
              <span class="phase-label">Current Focus</span>
              <h3 class="phase-title">Scaling Enterprise Systems</h3>
              <p class="phase-text">
                Working with DAX-listed enterprises and major EU players, my specialty is engineering <strong>performant, reliable distributed systems</strong>. I focus on optimizing database queries, building resilient microservices, and maintaining strict test-driven workflows to ensure code quality. Currently tackling domain complexity in payment services, with a proven track record across the energy and e-commerce sectors.
              </p>
            </div>
          </div>

          <div class="about-phase">
            <div class="phase-marker">
              <div class="phase-dot phase-dot-future"></div>
            </div>
            <div class="phase-content">
              <span class="phase-label">Next Steps</span>
              <h3 class="phase-title">Engineering for Impact</h3>
              <p class="phase-text">
                I'm looking to tackle high-complexity domain problems alongside inspiring engineering teams. I thrive in environments across Europe where code quality is non-negotiable, deployments are automated, and the architecture serves clear, measurable business goals.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="projects" class="projects-section">
      <div class="projects-container">
        <div class="projects-header">
          <h2>Case Studies</h2>
          <p>Real problems, deliberate architecture, measurable outcomes.</p>
        </div>

        <div class="projects-grid">
          <a href="/projects/immobile-search" class="project-link">
            <div class="project-card project-card-large">
              <div>
                <div class="project-header">
                  <h3 class="project-title">ImmoScout24 Austria</h3>
                  <span class="project-badge badge-live">LIVE</span>
                </div>
                <p class="project-description">
                  Top 3 real estate platform in Austria. Maintained and scaled a fully tested distributed system, optimizing critical path APIs, improving data throughput, and ensuring seamless third-party service integrations.
                </p>
                <div class="project-tech-container">
                  <span class="tech-pill"><TechIcon technology="React" size={16} />React</span>
                  <span class="tech-pill"><TechIcon technology="Node.js" size={16} />Node.js</span>
                  <span class="tech-pill"><TechIcon technology="AWS" size={16} />AWS</span>
                  <span class="tech-pill"><TechIcon technology="MongoDB" size={16} />MongoDB</span>
                </div>
              </div>
              <div class="project-results">
                <div class="results-header">
                  <span class="results-title">System Impact</span>
                </div>
                <ul class="results-list">
                  <li>Optimized data pipelines</li>
                  <li>High-availability API endpoints</li>
                  <li>Strict TDD & CI/CD workflows</li>
                </ul>
              </div>
            </div>
          </a>

          <a href="/projects/rwe-energy" class="project-link">
            <div class="project-card project-card-large project-card-reverse">
              <div class="project-results">
                <div class="results-header">
                  <span class="results-title">Impact</span>
                </div>
                <ul class="results-list">
                  <li>65% faster APIs</li>
                  <li>Exports: 45min to 12min</li>
                  <li>TDD from day one</li>
                </ul>
              </div>
              <div>
                <div class="project-header">
                  <h3 class="project-title">RWE Energy Platform</h3>
                  <span class="project-badge badge-enterprise">ENTERPRISE</span>
                </div>
                <p class="project-description">
                  Modernized legacy infrastructure by migrating a monolithic architecture to NestJS microservices. Addressed underlying database bottlenecks and utilized profiler-driven optimization to dramatically reduce heavy data export times.
                </p>
                <div class="project-tech-container">
                  <span class="tech-pill"><TechIcon technology="NestJS" size={16} />NestJS</span>
                  <span class="tech-pill"><TechIcon technology="MongoDB" size={16} />MongoDB</span>
                  <span class="tech-pill"><TechIcon technology="Docker" size={16} />Docker</span>
                  <span class="tech-pill"><TechIcon technology="TypeScript" size={16} />TypeScript</span>
                </div>
              </div>
            </div>
          </a>

          <a href="/projects/endava" class="project-link">
            <div class="project-card project-card-compact">
              <div class="project-compact-content">
                <div class="project-compact-info">
                  <h3 class="project-compact-title">
                    Endava — Deutsche Telekom, NETS, eLife Sciences
                  </h3>
                  <p class="project-compact-description">
                    Nearly 3 years engineering high-availability backends across telecoms, payments, and academic publishing. This period established my core standards for building reliable, secure distributed architecture.
                  </p>
                </div>
                <div class="project-compact-tech">
                  <span class="tech-pill"><TechIcon technology="React" size={16} />React & Node</span>
                  <span class="tech-pill"><TechIcon technology="AWS" size={16} />AWS Lambda</span>
                  <span class="tech-pill"><TechIcon technology="TypeScript" size={16} />TypeScript</span>
                </div>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <footer id="contact" class="footer-section">
      <div class="footer-container">
        <h3 class="footer-title">Let's discuss your next engineering challenge</h3>
        <p class="footer-subtitle">Available for senior engineering roles and long-term engagements across Europe</p>

        <div class="footer-contact-info">
          <div class="footer-contact-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
            <a href="mailto:contact@calingabriel.com">contact@calingabriel.com</a>
          </div>
          <div class="footer-contact-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            <a href="tel:+40759407066">+40 759 407 066</a>
          </div>
        </div>

        <div class="footer-social-container">
          <a
            href="https://www.linkedin.com/in/calingabriel-ts-dev/"
            target="_blank"
            rel="noopener"
            class="footer-social-link"
          >
            LinkedIn
          </a>
          <a
            href="https://github.com/calindotgabriel"
            target="_blank"
            rel="noopener"
            class="footer-social-link"
          >
            GitHub
          </a>
        </div>
      </div>
    </footer>

    <style>
      /* HEADER NAVIGATION */
      .header-nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        z-index: 1000;
        transition: all 0.3s ease;
      }

      .nav-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 70px;
      }

      .nav-logo a {
        text-decoration: none;
        color: var(--dark);
        display: flex;
        flex-direction: column;
        line-height: 1.1;
      }

      .logo-text {
        font-size: 1.3rem;
        font-weight: 700;
        background: linear-gradient(135deg, #6366f1 0%, #ec4899 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .logo-subtitle {
        font-size: 0.75rem;
        color: var(--gray);
        font-weight: 500;
      }

      .nav-desktop {
        display: flex;
        gap: 2rem;
        align-items: center;
      }

      .nav-link {
        text-decoration: none;
        color: var(--dark);
        font-weight: 500;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        position: relative;
        padding: 0.5rem 0;
      }

      .nav-link::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0;
        height: 2px;
        background: linear-gradient(135deg, #6366f1 0%, #ec4899 100%);
        transition: width 0.3s ease;
      }

      .nav-link:hover {
        color: var(--primary);
      }

      .nav-link:hover::after {
        width: 100%;
      }

      /* Hamburger Menu */
      .hamburger {
        display: none;
        flex-direction: column;
        gap: 4px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        transition: all 0.3s ease;
      }

      .hamburger-line {
        width: 25px;
        height: 2px;
        background: var(--dark);
        transition: all 0.3s ease;
        transform-origin: center;
      }

      .hamburger.active .hamburger-line:nth-child(1) {
        transform: rotate(45deg) translate(6px, 6px);
      }

      .hamburger.active .hamburger-line:nth-child(2) {
        opacity: 0;
      }

      .hamburger.active .hamburger-line:nth-child(3) {
        transform: rotate(-45deg) translate(6px, -6px);
      }

      /* Mobile Navigation */
      .nav-mobile {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        padding: 2rem;
        display: none;
        flex-direction: column;
        gap: 1.5rem;
        animation: slideDown 0.3s ease;
      }

      .nav-mobile.active {
        display: flex;
      }

      .nav-mobile-link {
        text-decoration: none;
        color: var(--dark);
        font-weight: 500;
        font-size: 1.1rem;
        padding: 1rem 0;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        transition: all 0.3s ease;
      }

      .nav-mobile-link:hover {
        color: var(--primary);
        transform: translateX(10px);
      }

      .nav-mobile-link:last-child {
        border-bottom: none;
      }

      @keyframes slideDown {
        from {
          opacity: 0;
          transform: translateY(-20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* Responsive Design */
      @media (max-width: 768px) {
        .nav-desktop {
          display: none;
        }

        .hamburger {
          display: flex;
        }

        .nav-container {
          padding: 0 1rem;
        }
      }

      /* Add padding to body to account for fixed header */
      body {
        padding-top: 70px;
      }


      /* HERO SECTION */
      .hero-section {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--dark);
        position: relative;
      }

      .hero-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background:
          radial-gradient(ellipse at 20% 50%, rgba(99, 102, 241, 0.15) 0%, transparent 50%),
          radial-gradient(ellipse at 80% 50%, rgba(236, 72, 153, 0.1) 0%, transparent 50%);
        pointer-events: none;
      }

      .hero-content {
        position: relative;
        z-index: 10;
        max-width: 750px;
        margin: 0 auto;
        padding: 2rem;
        color: white;
      }

      .hero-badge {
        display: inline-block;
        font-size: 0.85rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.7);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 50px;
        padding: 0.5rem 1.25rem;
        margin-bottom: 2rem;
        animation: fadeInUp 0.8s ease both;
      }

      .hero-title {
        font-size: 4rem;
        font-weight: 800;
        margin-bottom: 1.5rem;
        line-height: 1.1;
        color: white;
        animation: fadeInUp 0.8s ease 0.15s both;
      }

      .hero-tagline {
        font-size: 1.3rem;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.85);
        margin-bottom: 1.25rem;
        animation: fadeInUp 0.8s ease 0.3s both;
      }

      .hero-tagline strong {
        color: white;
        font-weight: 600;
      }

      .hero-sub {
        font-size: 1.05rem;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.5);
        margin-bottom: 2.5rem;
        animation: fadeInUp 0.8s ease 0.45s both;
      }

      .hero-cta {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        animation: fadeInUp 0.8s ease 0.6s both;
      }

      .cta-primary {
        display: inline-block;
        background: white;
        color: var(--dark);
        text-decoration: none;
        padding: 0.85rem 1.75rem;
        border-radius: 8px;
        font
