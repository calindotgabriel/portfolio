---
import BaseLayout from "../layouts/BaseLayout.astro";
import TechIcon from "../components/TechIcon.astro";

---

<BaseLayout 
  title="Calin Gabriel - Senior Full Stack Developer"
  description="Senior Full Stack Developer building scalable distributed systems with Node.js, React, and cloud infrastructure. 6+ years delivering for enterprise clients across Europe."
>
  <!-- HEADER NAVIGATION -->
  <header class="header-nav">
    <div class="nav-container">
      <div class="nav-logo">
        <a href="#hero">
          <span class="logo-text">Calin Gabriel</span>
          <span class="logo-subtitle">Full Stack Developer</span>
        </a>
      </div>
      
      <!-- Desktop Navigation -->
      <nav class="nav-desktop">
        <a href="#hero" class="nav-link">Home</a>
        <a href="#about" class="nav-link">About</a>
        <a href="#projects" class="nav-link">Projects</a>
        <a href="#contact" class="nav-link">Contact</a>
      </nav>
      
      <!-- Mobile Hamburger -->
      <button class="hamburger" id="hamburger" aria-label="Toggle navigation">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
    
    <!-- Mobile Navigation -->
    <nav class="nav-mobile" id="nav-mobile">
      <a href="#hero" class="nav-mobile-link">Home</a>
      <a href="#about" class="nav-mobile-link">About</a>
      <a href="#projects" class="nav-mobile-link">Projects</a>
      <a href="#contact" class="nav-mobile-link">Contact</a>
    </nav>
  </header>

  <!-- HERO SECTION -->
    <section id="hero" class="hero-section">
      <div class="hero-content">
        <span class="hero-badge">Open to Opportunities</span>

        <h1 class="hero-title">Calin Gabriel</h1>

        <p class="hero-tagline">
          I build distributed systems that handle real complexity —
          payments, energy, e-commerce — for companies like
          <strong>Scout24</strong>, <strong>RWE</strong>, and <strong>NETS</strong>.
        </p>

        <p class="hero-sub">
          From Galati at 16 to DAX-listed enterprises. 6+ years of shipping
          scalable backends, test-driven, across Europe.
        </p>

        <div class="hero-cta">
          <a href="#about" class="cta-primary">Read My Story</a>
          <a href="#projects" class="cta-secondary">See Case Studies</a>
          <a href="/cv.pdf" class="cta-secondary">Download CV</a>
        </div>
      </div>
    </section>

    <!-- ABOUT SECTION -->
    <section id="about" class="about-section">
      <div class="about-container">
        <h2 class="about-heading">The Story Behind the Code</h2>

        <div class="about-timeline">
          <!-- Past -->
          <div class="about-phase">
            <div class="phase-marker">
              <div class="phase-dot"></div>
              <div class="phase-line"></div>
            </div>
            <div class="phase-content">
              <span class="phase-label">Where I started</span>
              <h3 class="phase-title">From Galati at 16 to enterprise systems</h3>
              <p class="phase-text">
                At 16 I won an internship contest competing against college students in Galati.
                That firm hired me, and I learned Linux and web development hands-on before most
                people pick a major. I then moved to Cluj-Napoca for a Computer Science degree at
                Babes-Bolyai University — building the formal foundation under the practical instincts
                I already had.
              </p>
            </div>
          </div>

          <!-- Present -->
          <div class="about-phase">
            <div class="phase-marker">
              <div class="phase-dot phase-dot-active"></div>
              <div class="phase-line"></div>
            </div>
            <div class="phase-content">
              <span class="phase-label">Where I am now</span>
              <h3 class="phase-title">Fixing hard problems at scale</h3>
              <p class="phase-text">
                After graduating I worked with progressively larger companies — culminating with
                DAX-listed enterprises like RWE and Scout24, and major EU and US players.
                I'm a generalist by pedigree but a specialist where it counts:
                <strong>performant, scalable distributed systems</strong>. I iterate with tests,
                automate relentlessly, and use AI tooling to accelerate workflows — not to
                replace thinking, but to spend more time on the problems that actually matter.
                Currently focused on payment services, with strong experience across energy and e-commerce.
              </p>
            </div>
          </div>

          <!-- Future -->
          <div class="about-phase">
            <div class="phase-marker">
              <div class="phase-dot phase-dot-future"></div>
            </div>
            <div class="phase-content">
              <span class="phase-label">Where I'm heading</span>
              <h3 class="phase-title">Building what matters, with teams that think</h3>
              <p class="phase-text">
                I want to keep refining distributed systems that handle real complexity —
                not just traffic, but domain complexity. I'm looking for inspiring, smart
                engineering teams across Europe where high standards are the baseline
                and the problems are worth solving.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PROJECTS COMPACT -->
    <section id="projects" class="projects-section">
      <div class="projects-container">
        <div class="projects-header">
          <h2>Case Studies</h2>
          <p>Real problems, real decisions, real outcomes.</p>
        </div>

        <div class="projects-grid">
          <!-- Project 1: ImmoScout24 -->
          <a href="/projects/immobile-search" class="project-link">
            <div class="project-card project-card-large">
              <div>
                <div class="project-header">
                  <h3 class="project-title">ImmoScout24 Austria</h3>
                  <span class="project-badge badge-live">LIVE</span>
                </div>
                <p class="project-description">
                  Top 3 real estate platform in Austria. I adapted to a fully tested
                  distributed system, drove SEO to all-time highs, and integrated
                  marketing automation with Iterable.
                </p>
                <div class="project-tech-container">
                  <span class="tech-pill"><TechIcon technology="React" size={16} />React</span>
                  <span class="tech-pill"><TechIcon technology="Node.js" size={16} />Node.js</span>
                  <span class="tech-pill"><TechIcon technology="AWS" size={16} />AWS</span>
                  <span class="tech-pill"><TechIcon technology="MongoDB" size={16} />MongoDB</span>
                </div>
              </div>
              <div class="project-results">
                <div class="results-header">
                  <span class="results-title">Impact</span>
                </div>
                <ul class="results-list">
                  <li>SEO all-time high</li>
                  <li>20% higher engagement</li>
                  <li>Marketing automation live</li>
                </ul>
              </div>
            </div>
          </a>

          <!-- Project 2: RWE Energy -->
          <a href="/projects/rwe-energy" class="project-link">
            <div class="project-card project-card-large project-card-reverse">
              <div class="project-results">
                <div class="results-header">
                  <span class="results-title">Impact</span>
                </div>
                <ul class="results-list">
                  <li>65% faster APIs</li>
                  <li>Exports: 45min to 12min</li>
                  <li>TDD from day one</li>
                </ul>
              </div>
              <div>
                <div class="project-header">
                  <h3 class="project-title">RWE Energy Platform</h3>
                  <span class="project-badge badge-enterprise">ENTERPRISE</span>
                </div>
                <p class="project-description">
                  Migrated a slow Java monolith to NestJS microservices. I introduced
                  Worker Pools for parallel processing and used profiler-driven
                  optimization to fix the real bottlenecks.
                </p>
                <div class="project-tech-container">
                  <span class="tech-pill"><TechIcon technology="NestJS" size={16} />NestJS</span>
                  <span class="tech-pill"><TechIcon technology="MongoDB" size={16} />MongoDB</span>
                  <span class="tech-pill"><TechIcon technology="Docker" size={16} />Docker</span>
                  <span class="tech-pill"><TechIcon technology="TypeScript" size={16} />TypeScript</span>
                </div>
              </div>
            </div>
          </a>

          <!-- Project 3: Endava -->
          <a href="/projects/endava" class="project-link">
            <div class="project-card project-card-compact">
              <div class="project-compact-content">
                <div class="project-compact-info">
                  <h3 class="project-compact-title">
                    Endava — Deutsche Telekom, NETS, eLife Sciences
                  </h3>
                  <p class="project-compact-description">
                    Nearly 3 years rotating across telecoms, payments, and academic publishing.
                    The period that raised my bar and set the foundation for everything after.
                  </p>
                </div>
                <div class="project-compact-tech">
                  <span class="tech-pill"><TechIcon technology="React" size={16} />React & Node</span>
                  <span class="tech-pill"><TechIcon technology="AWS" size={16} />AWS Lambda</span>
                  <span class="tech-pill"><TechIcon technology="TypeScript" size={16} />TypeScript</span>
                </div>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- FOOTER CONTACT -->
    <footer id="contact" class="footer-section">
      <div class="footer-container">
        <h3 class="footer-title">Let's build something that scales</h3>
        <p class="footer-subtitle">Open to engineering roles and long-term engagements across Europe</p>

        <!-- Contact Information -->
        <div class="footer-contact-info">
          <div class="footer-contact-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
            <a href="mailto:contact@calingabriel.com">contact@calingabriel.com</a>
          </div>
          <div class="footer-contact-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            <a href="tel:+40759407066">+40 759 407 066</a>
          </div>
        </div>

        <div class="footer-social-container">
          <a
            href="https://www.linkedin.com/in/calingabriel-ts-dev/"
            target="_blank"
            rel="noopener"
            class="footer-social-link"
          >
            LinkedIn
          </a>
          <a
            href="https://github.com/calindotgabriel"
            target="_blank"
            rel="noopener"
            class="footer-social-link"
          >
            GitHub
          </a>
        </div>
      </div>
    </footer>

    <style>
      /* HEADER NAVIGATION */
      .header-nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        z-index: 1000;
        transition: all 0.3s ease;
      }

      .nav-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 70px;
      }

      .nav-logo a {
        text-decoration: none;
        color: var(--dark);
        display: flex;
        flex-direction: column;
        line-height: 1.1;
      }

      .logo-text {
        font-size: 1.3rem;
        font-weight: 700;
        background: linear-gradient(135deg, #6366f1 0%, #ec4899 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .logo-subtitle {
        font-size: 0.75rem;
        color: var(--gray);
        font-weight: 500;
      }

      .nav-desktop {
        display: flex;
        gap: 2rem;
        align-items: center;
      }

      .nav-link {
        text-decoration: none;
        color: var(--dark);
        font-weight: 500;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        position: relative;
        padding: 0.5rem 0;
      }

      .nav-link::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0;
        height: 2px;
        background: linear-gradient(135deg, #6366f1 0%, #ec4899 100%);
        transition: width 0.3s ease;
      }

      .nav-link:hover {
        color: var(--primary);
      }

      .nav-link:hover::after {
        width: 100%;
      }

      /* Hamburger Menu */
      .hamburger {
        display: none;
        flex-direction: column;
        gap: 4px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        transition: all 0.3s ease;
      }

      .hamburger-line {
        width: 25px;
        height: 2px;
        background: var(--dark);
        transition: all 0.3s ease;
        transform-origin: center;
      }

      .hamburger.active .hamburger-line:nth-child(1) {
        transform: rotate(45deg) translate(6px, 6px);
      }

      .hamburger.active .hamburger-line:nth-child(2) {
        opacity: 0;
      }

      .hamburger.active .hamburger-line:nth-child(3) {
        transform: rotate(-45deg) translate(6px, -6px);
      }

      /* Mobile Navigation */
      .nav-mobile {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        padding: 2rem;
        display: none;
        flex-direction: column;
        gap: 1.5rem;
        animation: slideDown 0.3s ease;
      }

      .nav-mobile.active {
        display: flex;
      }

      .nav-mobile-link {
        text-decoration: none;
        color: var(--dark);
        font-weight: 500;
        font-size: 1.1rem;
        padding: 1rem 0;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        transition: all 0.3s ease;
      }

      .nav-mobile-link:hover {
        color: var(--primary);
        transform: translateX(10px);
      }

      .nav-mobile-link:last-child {
        border-bottom: none;
      }

      @keyframes slideDown {
        from {
          opacity: 0;
          transform: translateY(-20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* Responsive Design */
      @media (max-width: 768px) {
        .nav-desktop {
          display: none;
        }

        .hamburger {
          display: flex;
        }

        .nav-container {
          padding: 0 1rem;
        }
      }

      /* Add padding to body to account for fixed header */
      body {
        padding-top: 70px;
      }


      /* HERO SECTION */
      .hero-section {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--dark);
        position: relative;
      }

      .hero-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background:
          radial-gradient(ellipse at 20% 50%, rgba(99, 102, 241, 0.15) 0%, transparent 50%),
          radial-gradient(ellipse at 80% 50%, rgba(236, 72, 153, 0.1) 0%, transparent 50%);
        pointer-events: none;
      }

      .hero-content {
        position: relative;
        z-index: 10;
        max-width: 750px;
        margin: 0 auto;
        padding: 2rem;
        color: white;
      }

      .hero-badge {
        display: inline-block;
        font-size: 0.85rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.7);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 50px;
        padding: 0.5rem 1.25rem;
        margin-bottom: 2rem;
        animation: fadeInUp 0.8s ease both;
      }

      .hero-title {
        font-size: 4rem;
        font-weight: 800;
        margin-bottom: 1.5rem;
        line-height: 1.1;
        color: white;
        animation: fadeInUp 0.8s ease 0.15s both;
      }

      .hero-tagline {
        font-size: 1.3rem;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.85);
        margin-bottom: 1.25rem;
        animation: fadeInUp 0.8s ease 0.3s both;
      }

      .hero-tagline strong {
        color: white;
        font-weight: 600;
      }

      .hero-sub {
        font-size: 1.05rem;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.5);
        margin-bottom: 2.5rem;
        animation: fadeInUp 0.8s ease 0.45s both;
      }

      .hero-cta {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        animation: fadeInUp 0.8s ease 0.6s both;
      }

      .cta-primary {
        display: inline-block;
        background: white;
        color: var(--dark);
        text-decoration: none;
        padding: 0.85rem 1.75rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s ease;
      }

      .cta-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(255, 255, 255, 0.15);
      }

      .cta-secondary {
        display: inline-block;
        color: rgba(255, 255, 255, 0.7);
        text-decoration: none;
        padding: 0.85rem 1.75rem;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        font-weight: 500;
        font-size: 0.95rem;
        transition: all 0.3s ease;
      }

      .cta-secondary:hover {
        color: white;
        border-color: rgba(255, 255, 255, 0.4);
      }

      .project-link {
        text-decoration: none;
        color: inherit;
      }

      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (max-width: 768px) {
        .hero-title {
          font-size: 2.75rem;
        }

        .hero-tagline {
          font-size: 1.1rem;
        }

        .hero-cta {
          flex-direction: column;
        }

        .cta-primary,
        .cta-secondary {
          text-align: center;
        }
      }      /* ABOUT SECTION */
      .about-section {
        padding: 100px 0;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
      }

      .about-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 2rem;
      }

      .about-heading {
        font-size: 2.5rem;
        font-weight: 800;
        text-align: center;
        margin-bottom: 4rem;
        background: linear-gradient(135deg, #6366f1 0%, #ec4899 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .about-timeline {
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      .about-phase {
        display: flex;
        gap: 2rem;
        padding-bottom: 3rem;
      }

      .about-phase:last-child {
        padding-bottom: 0;
      }

      .phase-marker {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex-shrink: 0;
        width: 20px;
      }

      .phase-dot {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: #cbd5e1;
        border: 3px solid #e2e8f0;
        flex-shrink: 0;
        position: relative;
        z-index: 2;
      }

      .phase-dot-active {
        background: var(--primary);
        border-color: rgba(99, 102, 241, 0.3);
        box-shadow: 0 0 12px rgba(99, 102, 241, 0.4);
      }

      .phase-dot-future {
        background: linear-gradient(135deg, #6366f1 0%, #ec4899 100%);
        border-color: rgba(236, 72, 153, 0.3);
      }

      .phase-line {
        width: 2px;
        flex-grow: 1;
        background: linear-gradient(180deg, #e2e8f0 0%, #cbd5e1 100%);
        margin-top: 0.5rem;
      }

      .phase-content {
        padding-top: 0;
      }

      .phase-label {
        display: inline-block;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--primary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.5rem;
      }

      .phase-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--dark);
        margin-bottom: 0.75rem;
        line-height: 1.3;
      }

      .phase-text {
        font-size: 1.05rem;
        line-height: 1.75;
        color: var(--gray);
      }

      .phase-text strong {
        color: var(--dark);
        font-weight: 600;
      }

      @media (max-width: 768px) {
        .about-heading {
          font-size: 2rem;
        }

        .about-phase {
          gap: 1.25rem;
        }

        .phase-title {
          font-size: 1.2rem;
        }

        .phase-text {
          font-size: 1rem;
        }
      }

      /* Footer Contact Information */
      .footer-title {
        color: white;
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 1rem;
        text-align: center;
      }

      .footer-subtitle {
        color: rgba(255, 255, 255, 0.8);
        font-size: 1.1rem;
        margin-bottom: 2.5rem;
        text-align: center;
      }

      .footer-contact-info {
        display: flex;
        gap: 2.5rem;
        justify-content: center;
        align-items: center;
        margin: 2.5rem 0;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 50px;
        padding: 1.5rem 2.5rem;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
      }

      .footer-contact-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: rgba(255, 255, 255, 0.95);
        font-size: 1.1rem;
        font-weight: 500;
      }

      .footer-contact-item svg {
        color: #fbbf24;
        flex-shrink: 0;
      }

      .footer-contact-item a {
        color: rgba(255, 255, 255, 0.95);
        text-decoration: none;
        transition: all 0.3s ease;
        font-weight: 500;
      }

      .footer-contact-item a:hover {
        color: #fbbf24;
        transform: translateY(-1px);
      }

      /* Mobile responsive for footer contact */
      @media (max-width: 768px) {
        .footer-contact-info {
          flex-direction: column;
          gap: 1.5rem;
          padding: 1.5rem 2rem;
          margin: 2rem auto;
          max-width: 320px;
        }

        .footer-contact-item {
          font-size: 1rem;
          justify-content: center;
        }

        .footer-title {
          font-size: 1.5rem;
        }

        .footer-subtitle {
          font-size: 1rem;
        }
      }
    </style>

    <script>
      // Hamburger menu functionality
      document.addEventListener('DOMContentLoaded', function() {
        const hamburger = document.getElementById('hamburger');
        const navMobile = document.getElementById('nav-mobile');
        const mobileLinks = document.querySelectorAll('.nav-mobile-link');
        const allNavLinks = document.querySelectorAll('.nav-link, .nav-mobile-link');
        const header = document.querySelector('.header-nav') as HTMLElement;

        if (!hamburger || !navMobile || !header) return;

        // Toggle mobile menu
        hamburger.addEventListener('click', function() {
          hamburger.classList.toggle('active');
          navMobile.classList.toggle('active');
        });

        // Close mobile menu when clicking on a link
        mobileLinks.forEach(link => {
          link.addEventListener('click', function() {
            hamburger.classList.remove('active');
            navMobile.classList.remove('active');
          });
        });

        // Smooth scroll to sections
        allNavLinks.forEach(link => {
          link.addEventListener('click', function(e) {
            e.preventDefault();
            const href = (e.target as HTMLAnchorElement).getAttribute('href');
            if (!href) return;
            
            const targetSection = document.querySelector(href);
            
            if (targetSection) {
              const headerHeight = 70;
              const offsetTop = (targetSection as HTMLElement).offsetTop - headerHeight;
              
              window.scrollTo({
                top: offsetTop,
                behavior: 'smooth'
              });
            }
          });
        });

        // Header background on scroll
        let lastScrollY = window.scrollY;

        window.addEventListener('scroll', function() {
          const currentScrollY = window.scrollY;
          
          if (currentScrollY > 50) {
            header.style.background = 'rgba(255, 255, 255, 0.98)';
            header.style.boxShadow = '0 2px 20px rgba(0, 0, 0, 0.1)';
          } else {
            header.style.background = 'rgba(255, 255, 255, 0.95)';
            header.style.boxShadow = 'none';
          }
          
          lastScrollY = currentScrollY;
        });

        // Close mobile menu when clicking outside
        document.addEventListener('click', function(e) {
          const target = e.target as Node;
          if (!header.contains(target) && navMobile.classList.contains('active')) {
            hamburger.classList.remove('active');
            navMobile.classList.remove('active');
          }
        });
      });
    </script>
</BaseLayout>
