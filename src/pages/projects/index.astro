---
import ProjectLayout from "../../components/ProjectLayout.astro";
import { projects } from "../../data/projects";

const statusLabel: Record<string, string> = {
  LIVE: "Live",
  ENTERPRISE: "Enterprise",
  AGENCY: "Agency",
};
---

<ProjectLayout
  title="Case Studies"
  description="Case studies: real backend problems, real decisions, real outcomes — migrations, performance, and tested product delivery."
>
  <div class="ed-wrap">
    <section class="ed-hero">
      <p class="ed-kicker">Index · {projects.length} case files</p>
      <h1>Case files.</h1>
      <p class="ed-hero-lead">Real problems, real decisions, real outcomes — the messy, high-context backend work where a senior actually earns the seat.</p>
    </section>

    <div class="case-list">
      {projects.map((project, i) => (
        <a href={`/projects/${project.id}`} class="case">
          <span class="case-index">{String(i + 1).padStart(2, "0")}</span>
          <div class="case-main">
            <div class="case-top">
              <h2>{project.title}</h2>
              <span class:list={["ed-status", `is-${project.status.toLowerCase()}`]}>
                {statusLabel[project.status]}
              </span>
            </div>
            <p class="case-summary">{project.shortDescription}</p>
            <div class="case-tech">
              {project.tech.map((t) => <span class="mono-pill">{t}</span>)}
            </div>
          </div>
          <span class="case-arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </div>
  </div>
</ProjectLayout>

<style>
  .case-list { display: grid; gap: 0; margin-bottom: 1.5rem; }
  .case {
    display: grid;
    grid-template-columns: 3.5rem 1fr 1.5rem;
    gap: clamp(1rem, 3vw, 2.5rem);
    align-items: start;
    padding: 2.2rem 0;
    border-top: 1px solid var(--border-strong);
    text-decoration: none;
    color: inherit;
    position: relative;
    transition: padding-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .case:last-child { border-bottom: 1px solid var(--border-strong); }
  .case::before { content: ""; position: absolute; left: -1.5rem; top: 0; bottom: 0; width: 2px; background: var(--secondary); transform: scaleY(0); transform-origin: top; transition: transform 0.3s ease; }
  .case:hover { padding-left: 0.6rem; }
  .case:hover::before { transform: scaleY(1); }
  .case-index { font-family: var(--font-mono); font-size: 0.82rem; color: var(--secondary); padding-top: 0.5rem; }
  .case-top { display: flex; align-items: baseline; gap: 0.9rem; flex-wrap: wrap; margin-bottom: 0.7rem; }
  .case-top h2 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.3rem, 2.6vw, 1.9rem); letter-spacing: -0.01em; margin: 0; color: var(--text); }
  .case-summary { font-family: var(--font-body); font-size: 1.06rem; line-height: 1.6; color: var(--text-muted); margin-bottom: 1rem; max-width: 60ch; }
  .case-tech { display: flex; flex-wrap: wrap; gap: 0.45rem; }
  .case-arrow { font-size: 1.3rem; color: var(--text-subtle); padding-top: 0.3rem; transition: transform 0.3s ease, color 0.2s ease; }
  .case:hover .case-arrow { transform: translate(4px, -4px); color: var(--secondary); }

  @media (max-width: 720px) {
    .case { grid-template-columns: 2.5rem 1fr; }
    .case-arrow { display: none; }
  }
</style>
