---
import ProjectLayout from "../../components/ProjectLayout.astro";
import TechIcon from "../../components/TechIcon.astro";
import { projects } from "../../data/projects.js";
---

<ProjectLayout
  title="All Projects"
  description="Complete portfolio of development projects"
>
  <main>
    <section class="projects-hero">
      <div class="projects-hero-content">
        <h1>Case Studies</h1>
        <p>Real problems, real decisions, real outcomes.</p>
      </div>
    </section>

    <section class="projects-grid-section">
      <div class="projects-grid">
        {
          projects.map((project) => (
            <a href={`/projects/${project.id}`} class="project-card-link">
              <article class="project-card">
                <div class="project-card-header">
                  <h2>{project.title}</h2>
                  <span
                    class:list={["project-badge", {
                      "badge-live": project.status === "LIVE",
                      "badge-enterprise": project.status === "ENTERPRISE",
                      "badge-agency": project.status === "AGENCY",
                    }]}
                  >
                    {project.status}
                  </span>
                </div>
                <p class="project-card-desc">{project.shortDescription}</p>
                <div class="tech-pills">
                  {project.tech.map((tech: string) => (
                    <span class="tech-pill">
                      <TechIcon technology={tech} size={16} />
                      {tech}
                    </span>
                  ))}
                </div>
              </article>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</ProjectLayout>

<style>
  .projects-hero {
    background: var(--dark);
    color: white;
    padding: 5rem 0 3.5rem;
    text-align: center;
    position: relative;
  }

  .projects-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(99, 102, 241, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 50%, rgba(236, 72, 153, 0.08) 0%, transparent 50%);
    pointer-events: none;
  }

  .projects-hero-content {
    position: relative;
    z-index: 2;
    padding: 0 2rem;
  }

  .projects-hero h1 {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .projects-hero p {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .projects-grid-section {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 24px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 2rem;
  }

  .project-card-link {
    text-decoration: none;
    color: inherit;
  }

  .project-card {
    background: var(--gradient-card);
    border-radius: 16px;
    box-shadow: var(--shadow-md);
    border: 1px solid rgba(0, 0, 0, 0.06);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: all 0.3s ease;
    animation: fadeInUp 0.6s ease forwards;
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .project-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .project-card-header h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--dark);
    margin: 0;
  }

  .project-badge {
    padding: 0.2rem 0.65rem;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
    color: white;
    flex-shrink: 0;
  }

  .badge-live { background: #10b981; }
  .badge-enterprise { background: var(--primary); }
  .badge-agency { background: var(--gray); }

  .project-card-desc {
    font-size: 1rem;
    color: var(--gray);
    line-height: 1.6;
    flex-grow: 1;
  }

  .tech-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
  }

  .tech-pill {
    padding: 0.35rem 0.75rem;
    background: rgba(99, 102, 241, 0.08);
    color: var(--primary);
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.8rem;
    border: 1px solid rgba(99, 102, 241, 0.15);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .projects-hero h1 { font-size: 2.25rem; }
    .projects-hero p { font-size: 1rem; }
    .projects-grid { grid-template-columns: 1fr; }
    .project-card { padding: 1.5rem; }
  }
</style>
