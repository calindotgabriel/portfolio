---
export interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

import BaseLayout from "../layouts/BaseLayout.astro";
import ThemeToggle from "./ThemeToggle.astro";
import ContactFooter from "./ContactFooter.astro";
import "../styles/global.css";
---

<BaseLayout title={title} description={description}>
  <header class="masthead">
    <div class="masthead-rule"></div>
    <div class="masthead-inner">
      <a class="mast-id" href="/">
        <span class="mast-name">Calin Gabriel</span>
        <span class="mast-role">Senior Backend Engineer · Node.js / TypeScript</span>
      </a>
      <nav class="mast-nav" aria-label="Sections">
        <a href="/">Home</a>
        <a href="/projects">Case files</a>
        <a href="https://github.com/calindotgabriel" target="_blank" rel="noopener">GitHub</a>
        <a href="https://www.linkedin.com/in/calingabriel-ts-dev/" target="_blank" rel="noopener">LinkedIn</a>
      </nav>
      <div class="mast-actions">
        <ThemeToggle />
      </div>
    </div>
    <div class="masthead-rule thin"></div>
  </header>

  <main>
    <slot />
  </main>

  <ContactFooter />
</BaseLayout>

<style>
  :global(body) { padding-top: 0; }

  .masthead {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--page-bg) 88%, transparent);
    backdrop-filter: blur(8px) saturate(1.1);
  }
  .masthead-rule { height: 2px; background: var(--text); }
  .masthead-rule.thin { height: 1px; background: var(--border-strong); }
  .masthead-inner {
    max-width: 940px;
    margin: 0 auto;
    padding: 0.7rem clamp(1.25rem, 5vw, 3rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .mast-id { text-decoration: none; color: var(--text); display: flex; flex-direction: column; line-height: 1.15; }
  .mast-name { font-family: var(--font-display); font-weight: 600; font-size: 1.18rem; letter-spacing: -0.01em; }
  .mast-role { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); }

  .mast-nav { display: flex; gap: 1.5rem; font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.04em; }
  .mast-nav a { text-decoration: none; color: var(--text-muted); text-transform: uppercase; position: relative; padding-bottom: 2px; transition: color 0.2s ease; }
  .mast-nav a:hover { color: var(--text); }
  .mast-nav a::after { content: ""; position: absolute; left: 0; bottom: -2px; height: 1px; width: 0; background: var(--secondary); transition: width 0.25s ease; }
  .mast-nav a:hover::after { width: 100%; }

  .mast-actions { display: flex; align-items: center; }

  @media (max-width: 720px) {
    .mast-nav { display: none; }
    .mast-role { display: none; }
  }
</style>
