---
export interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

import BaseLayout from "../layouts/BaseLayout.astro";
import ThemeToggle from "./ThemeToggle.astro";
import ContactFooter from "./ContactFooter.astro";
import "../styles/global.css";
---

<BaseLayout title={title} description={description}>
  <!-- Navigation -->
  <header class="project-header">
    <div class="project-header-content">
      <a href="/" class="project-nav-logo">Calin Gabriel</a>
      <nav class="project-nav-links">
        <a href="/" class="project-nav-link">Home</a>
        <a href="/projects" class="project-nav-link">Projects</a>
        <a
          href="https://github.com/calindotgabriel"
          target="_blank"
          rel="noopener"
          class="project-nav-link">GitHub</a>
        <a
          href="https://www.linkedin.com/in/calingabriel-ts-dev/"
          target="_blank"
          rel="noopener"
          class="project-nav-link">LinkedIn</a>
      </nav>
      <ThemeToggle />
    </div>
  </header>

  <main>
    <slot />
  </main>

  <ContactFooter />
</BaseLayout>

<style>
  .project-header {
    background: var(--hero-bg);
    color: white;
    padding: 1.25rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .project-header-content {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 0 24px;
  }

  .project-nav-logo {
    font-size: 1.3rem;
    font-weight: 700;
    text-decoration: none;
    color: white;
  }

  .project-nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .project-nav-link {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9rem;
    transition: color 0.2s ease;
  }

  .project-nav-link:hover {
    color: white;
  }

  .project-footer {
    background: var(--hero-bg);
    color: white;
    padding: 4rem 0;
    text-align: center;
  }

  .project-footer-container {
    max-width: 600px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .project-footer-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .project-footer-subtitle {
    color: rgba(255, 255, 255, 0.6);
    font-size: 1rem;
    margin-bottom: 2rem;
  }

  .project-footer-cta {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .project-footer-link {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .project-footer-link:hover {
    color: white;
  }

  .project-footer-social {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .project-footer-social-link {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s ease;
  }

  .project-footer-social-link:hover {
    color: white;
  }

  @media (max-width: 768px) {
    .project-header-content {
      justify-content: center;
    }

    .project-nav-links {
      gap: 1rem;
      order: 3;
      width: 100%;
      justify-content: center;
      flex-wrap: wrap;
    }

    .project-nav-link {
      font-size: 0.85rem;
    }

    .project-footer-cta {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
