---
const email = "contact@calingabriel.com";
const mailto = `mailto:${email}?subject=Senior%20Node.js%20%2F%20TypeScript%20contract`;
const year = new Date().getFullYear();
---

<footer class="colophon" id="contact">
  <div class="colophon-wrap">
    <div class="colophon-rule"></div>
    <div class="colophon-grid">
      <div class="colophon-lead">
        <h2>Need a senior who can move risky backend work without adding chaos?</h2>
        <a href={mailto} class="btn-ink">Book a 20-minute fit call</a>
      </div>
      <dl class="colophon-meta">
        <div><dt>Email</dt><dd><a href={mailto}>{email}</a></dd></div>
        <div><dt>Phone</dt><dd><a href="tel:+40759407066">+40 759 407 066</a></dd></div>
        <div><dt>GitHub</dt><dd><a href="https://github.com/calindotgabriel" rel="me">github.com/calindotgabriel</a></dd></div>
        <div><dt>LinkedIn</dt><dd><a href="https://www.linkedin.com/in/calingabriel-ts-dev/" rel="me">/calingabriel-ts-dev</a></dd></div>
        <div><dt>Engagement</dt><dd>Remote EU · B2B · available now</dd></div>
      </dl>
    </div>
    <p class="colophon-sign">Set in Fraunces &amp; Newsreader. Built with Astro, no template. © {year} Calin Gabriel.</p>
  </div>
</footer>

<style>
  .colophon { padding: clamp(3rem, 7vw, 5rem) 0 4rem; }
  .colophon-wrap { max-width: 940px; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 3rem); }
  .colophon-rule { height: 2px; background: var(--text); margin-bottom: 2.6rem; }
  .colophon-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
    margin-bottom: 3rem;
  }
  .colophon-lead h2 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.6rem, 3.4vw, 2.4rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0 0 1.6rem;
    color: var(--text);
    max-width: 20ch;
  }
  .btn-ink {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.85rem 1.4rem;
    border-radius: 2px;
    background: var(--text);
    color: var(--page-bg);
    border: 1px solid var(--text);
    transition: transform 0.18s ease, background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  .btn-ink:hover { transform: translateY(-2px); background: var(--secondary); border-color: var(--secondary); color: #fff; }

  .colophon-meta { display: grid; gap: 0; margin: 0; }
  .colophon-meta > div { display: grid; grid-template-columns: 7rem 1fr; gap: 1rem; padding: 0.75rem 0; border-top: 1px solid var(--border); }
  .colophon-meta dt { font-family: var(--font-mono); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-subtle); }
  .colophon-meta dd { margin: 0; font-family: var(--font-mono); font-size: 0.82rem; color: var(--text); }
  .colophon-meta a { color: var(--text); text-decoration: none; border-bottom: 1px solid var(--secondary); transition: color 0.2s ease; }
  .colophon-meta a:hover { color: var(--secondary); }
  .colophon-sign { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-subtle); border-top: 1px solid var(--border); padding-top: 1.4rem; max-width: none; }

  @media (max-width: 720px) {
    .colophon-grid { grid-template-columns: 1fr; }
  }
</style>
